# App
APP_NAME=EasyInventory API
DEBUG=false

# Database (PR-02)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/easyinventory

# Cognito (PR-03)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# AWS Credentials (for Cognito admin operations like invite)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bootstrap Admin (PR-06)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ORG_NAME=Default Organization